# Server
PORT=5000

# MongoDB – use a local URI or MongoDB Atlas connection string
# Local MongoDB (default port):
MONGODB_URI=mongodb://127.0.0.1:27017/chatup
# Or MongoDB Atlas (replace with your cluster URL and DB name):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chatup

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production
